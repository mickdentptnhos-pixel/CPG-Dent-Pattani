            consultBody: true
          };
        }
      }

      /* ---- Elective ---- */
      if (ctx.proc === "elective") {
        const g = a.group;
        if (!g) return { status: null };

        if (g === "1") return {
          status: "green", title: "ให้การรักษาตามปกติ",
          message: "สามารถให้การรักษาทางทันตกรรมได้ตามปกติ"
        };

        if (g === "2") return {
          status: "green", title: "ให้การรักษาตามปกติ",
          message: "สามารถให้การรักษาทางทันตกรรมได้ตามปกติ "
                 + "และแนะนำให้ผู้ป่วยไปพบแพทย์เพื่อรักษา/ควบคุมความดันโลหิตสูง"
