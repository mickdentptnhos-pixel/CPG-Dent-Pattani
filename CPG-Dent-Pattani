                 + "• หรือ พิจารณาให้การรักษาที่ห้องฉุกเฉินหรือห้องผ่าตัด"
        };
      }

      /* ---- Urgency ---- */
      if (ctx.proc === "urgency") {
        const g = a.group;
        if (!g) return { status: null };

        if (g === "1") return {
          status: "green", title: "ให้การรักษาตามปกติ",
