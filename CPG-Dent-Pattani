<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clinical Practice Guideline – กลุ่มภารกิจด้านทันตกรรม โรงพยาบาลปัตตานี</title>
<style>
  :root{
    --blue-900:#0b3d70;
    --blue-700:#1565c0;
    --blue-600:#1976d2;
    --blue-500:#2196f3;
    --blue-50:#e8f2fd;
    --blue-25:#f4f9ff;
    --green-bg:#e6f7ed;
    --green-bd:#2e9e5b;
    --green-tx:#176a39;
    --red-bg:#fdecec;
    --red-bd:#d93636;
    --red-tx:#9b1c1c;
    --amber-bg:#fff6e5;
    --amber-bd:#e0a200;
    --amber-tx:#8a6100;
    --gray-700:#3a4250;
    --gray-500:#6b7280;
    --gray-300:#d6dbe2;
    --gray-100:#eef1f5;
    --shadow:0 2px 14px rgba(13,61,112,.08);
    --tap:48px; /* ขนาดแตะขั้นต่ำ พอดีนิ้ว */
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{margin:0;padding:0}
  body{
    font-family:"Sarabun","Segoe UI",Tahoma,sans-serif;
    background:linear-gradient(180deg,#f0f6fe 0%,#f7fafd 100%);
    color:var(--gray-700);
    min-height:100vh;
    line-height:1.55;
    -webkit-text-size-adjust:100%;
  }

  /* ---------- App shell ---------- */
  .app{max-width:880px;margin:0 auto;padding:18px 14px 64px}
  header.app-head{
    display:flex;align-items:center;gap:13px;
    padding:16px 18px;background:#fff;border-radius:14px;
    box-shadow:var(--shadow);border:1px solid var(--gray-100);
  }
  .logo{
    width:44px;height:44px;border-radius:12px;flex:0 0 auto;
    background:linear-gradient(135deg,var(--blue-600),var(--blue-900));
    display:flex;align-items:center;justify-content:center;color:#fff;font-size:23px;
  }
  .app-head h1{font-size:16px;margin:0;color:var(--blue-900);font-weight:700;line-height:1.35}
  .app-head p{margin:2px 0 0;font-size:12.5px;color:var(--gray-500)}

  .card{
    background:#fff;border-radius:14px;box-shadow:var(--shadow);
    border:1px solid var(--gray-100);padding:18px;margin-top:16px;
  }
  .card h2{
    font-size:15px;margin:0 0 14px;color:var(--blue-700);font-weight:700;
    display:flex;align-items:center;gap:8px;
  }
  .hint{font-size:13px;color:var(--gray-500);margin:-6px 0 14px}

  /* ---------- Chips ---------- */
  .chips{display:flex;flex-wrap:wrap;gap:10px}
  .chips.stack{flex-direction:column}
  .chip{
    border:1.5px solid var(--gray-300);background:#fff;border-radius:999px;
    padding:11px 18px;min-height:var(--tap);font-size:15px;font-family:inherit;color:var(--gray-700);
    cursor:pointer;transition:.15s;display:inline-flex;align-items:center;gap:8px;font-weight:600;text-align:left;
  }
  .chips.stack .chip{border-radius:12px;width:100%;justify-content:flex-start}
  .chip .dot{font-size:18px;line-height:1;flex:0 0 auto}
  .chip .sub{display:block;font-weight:400;font-size:12.5px;color:var(--gray-500);margin-top:2px}
  .chip.active .sub{color:rgba(255,255,255,.85)}
  .chip .sub-list{margin:4px 0 0 14px;padding:0;list-style:disc;font-size:12.5px;font-weight:400;color:var(--gray-500);line-height:1.5}
  .chip.active .sub-list{color:rgba(255,255,255,.85)}
  .chip:hover{border-color:var(--blue-500);background:var(--blue-25)}
  .chip:active{transform:scale(.98)}
  .chip.active{border-color:var(--blue-600);background:var(--blue-600);color:#fff;box-shadow:0 3px 10px rgba(25,118,210,.3)}

  /* ---------- Decision flow ---------- */
  .sub-block{margin-top:16px;padding-top:16px;border-top:1px dashed var(--gray-300)}
  .sub-block:first-child{margin-top:0;padding-top:0;border-top:none}
  .q-label{font-size:15px;font-weight:600;color:var(--gray-700);margin-bottom:10px}
  .choices{display:flex;flex-wrap:wrap;gap:10px}
  .choice{
    flex:1 1 auto;min-width:140px;min-height:var(--tap);
    border:1.5px solid var(--gray-300);background:#fff;border-radius:11px;
    padding:11px 16px;font-size:15px;font-family:inherit;color:var(--gray-700);cursor:pointer;transition:.15s;
    display:flex;align-items:center;justify-content:center;gap:7px;font-weight:600;
  }
  .choice:hover{border-color:var(--blue-500);background:var(--blue-25)}
  .choice:active{transform:scale(.98)}
  .choice.active{border-color:var(--blue-600);background:var(--blue-600);color:#fff}
  .inline-input{display:flex;align-items:center;gap:10px;margin-top:12px;flex-wrap:wrap}
  .inline-input input{
    flex:1 1 160px;min-height:var(--tap);padding:11px 14px;border:1.5px solid var(--gray-300);
    border-radius:11px;font-size:16px;font-family:inherit;
  }
  .inline-input input:focus{outline:none;border-color:var(--blue-500);box-shadow:0 0 0 3px var(--blue-50)}

  /* ---------- Result box ---------- */
  .result{margin-top:0;border-radius:12px;padding:16px 18px;font-size:15px;display:none;animation:fade .25s}
  @keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
  .result.show{display:block}
  .result .r-title{font-weight:700;font-size:16px;display:flex;align-items:center;gap:9px;margin-bottom:5px}
  .result.green{background:var(--green-bg);border:1.5px solid var(--green-bd);color:var(--green-tx)}
  .result.red{background:var(--red-bg);border:1.5px solid var(--red-bd);color:var(--red-tx)}
  .result.amber{background:var(--amber-bg);border:1.5px solid var(--amber-bd);color:var(--amber-tx)}
  .result .ico{font-size:21px}
  .result .r-body{white-space:pre-wrap}

  /* ---------- Patient form (revealed when consult needed) ---------- */
  #patientCard{display:none}
  .grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:13px}
  @media(max-width:560px){.grid{grid-template-columns:1fr 1fr}.grid .field.full{grid-column:1 / -1}}
  .field label{display:block;font-size:13px;color:var(--gray-500);margin-bottom:6px;font-weight:600}
  .field input{
    width:100%;min-height:var(--tap);padding:11px 13px;border:1.5px solid var(--gray-300);border-radius:11px;
    font-size:16px;font-family:inherit;color:var(--gray-700);background:#fff;transition:.15s;
  }
  .field input:focus{outline:none;border-color:var(--blue-500);box-shadow:0 0 0 3px var(--blue-50)}
  .privacy-note{
    margin-top:12px;font-size:12.5px;color:var(--gray-500);
    background:var(--blue-25);border:1px dashed var(--blue-500);border-radius:9px;padding:9px 12px;
  }
  .privacy-note b{color:var(--blue-700)}

  .actions{margin-top:16px;display:flex;gap:10px;flex-wrap:wrap}
  .btn{
    min-height:var(--tap);border:none;border-radius:11px;padding:12px 22px;font-size:16px;
    font-family:inherit;font-weight:700;cursor:pointer;transition:.15s;
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
  }
  .btn:active{transform:scale(.98)}
  .btn-primary{background:var(--blue-600);color:#fff}
  .btn-primary:hover{background:var(--blue-700)}
  .btn-ghost{background:#fff;color:var(--gray-700);border:1.5px solid var(--gray-300)}
  .btn-ghost:hover{border-color:var(--blue-500);color:var(--blue-700)}
  .btn-block{flex:1 1 100%}
  @media(min-width:480px){.btn-block{flex:0 1 auto}}

  /* ---------- A4 Consult document ---------- */
  #consultDoc{display:none;padding:14px}
  .a4{
    background:#fff;width:210mm;max-width:100%;min-height:297mm;margin:0 auto;padding:22mm 20mm;
    box-shadow:0 4px 24px rgba(0,0,0,.12);color:#1a1a1a;font-size:15px;line-height:1.7;
  }
  @media(max-width:760px){.a4{min-height:auto;padding:24px 20px}}
  .a4 .doc-head{text-align:center;border-bottom:2.5px solid var(--blue-900);padding-bottom:12px;margin-bottom:8px}
  .a4 .doc-head h2{margin:0;font-size:20px;color:var(--blue-900)}
  .a4 .doc-head p{margin:3px 0 0;font-size:14px;color:#444}
  .a4 .doc-title{text-align:center;font-size:18px;font-weight:700;margin:18px 0 22px;letter-spacing:1px}
  .a4 .pt-row{display:flex;flex-wrap:wrap;gap:6px 30px;margin-bottom:8px}
  .a4 .pt-row span{font-size:15px}
  .a4 .sec{margin-top:20px}
  .a4 .sec-h{font-weight:700;color:var(--blue-900);border-left:4px solid var(--blue-700);padding-left:9px;margin-bottom:8px}
  .a4 .body-txt{white-space:pre-wrap}
  .a4 .sign{margin-top:46px;display:flex;justify-content:flex-end;text-align:center}
  .a4 .sign .line{width:250px;padding-top:6px;font-size:14px}
  .a4 .meta{margin-top:30px;font-size:13px;color:#555;border-top:1px solid #ccc;padding-top:8px}
  .doc-toolbar{
    max-width:210mm;margin:0 auto 14px;display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;
  }
  @media(max-width:480px){.doc-toolbar .btn{flex:1 1 100%}}

  /* ---------- Print ---------- */
  @media print{
    body{background:#fff}
    .app,.doc-toolbar{display:none !important}
    #consultDoc{display:block !important;padding:0}
    .a4{box-shadow:none;width:auto;min-height:auto;margin:0;padding:14mm 16mm}
    @page{size:A4;margin:0}
  }
</style>
</head>
<body>

<!-- ============ MAIN APP ============ -->
<div class="app" id="app">

  <header class="app-head">
    <div class="logo">🦷</div>
    <div>
      <h1>Clinical Practice Guideline</h1>
      <p>กลุ่มภารกิจด้านทันตกรรม โรงพยาบาลปัตตานี</p>
    </div>
  </header>

  <!-- 1. Problem List (chips) — แสดงก่อนเสมอ -->
  <section class="card" id="problemCard">
    <h2>เลือก Problem List</h2>
    <p class="hint">แตะเลือกปัญหาทางคลินิกของผู้ป่วย</p>
    <div class="chips" id="problemChips">
      <button class="chip" type="button" data-problem="ht"><span class="dot">🫀</span> ความดันโลหิตสูง</button>
      <button class="chip" type="button" data-problem="warfarin"><span class="dot">💊</span> Warfarin</button>
      <button class="chip" type="button" data-problem="aspirin"><span class="dot">💊</span> Aspirin</button>
    </div>
  </section>

  <!-- 2. Procedure urgency (chips) — แสดงหลังเลือก Problem -->
  <section class="card" id="procCard" style="display:none">
    <h2>เลือกประเภทหัตถการ (ความเร่งด่วน)</h2>
    <p class="hint">แตะเลือกระดับความเร่งด่วน</p>
    <div class="chips" id="procChips">
      <button class="chip" type="button" data-proc="emergency"><span class="dot">🚑</span> Emergency</button>
      <button class="chip" type="button" data-proc="urgency"><span class="dot">⏱️</span> Urgency</button>
      <button class="chip" type="button" data-proc="elective"><span class="dot">🗓️</span> Elective</button>
    </div>
  </section>

  <!-- 3. Procedure (chips) -->
  <section class="card" id="procedureCard" style="display:none">
    <h2>เลือกหัตถการ</h2>
    <p class="hint">แตะเลือกชนิดหัตถการที่จะทำ</p>
    <div class="chips stack" id="procedureChips"><!-- สร้างจาก JS ตาม Problem ที่เลือก --></div>
  </section>

  <!-- 4. Decision questions -->
  <section class="card" id="decisionCard" style="display:none">
    <h2>ประเมินเงื่อนไข</h2>
    <div id="decisionArea"></div>
  </section>

  <!-- 5. Recommendation result -->
  <section class="card" id="resultCard" style="display:none">
    <h2>คำแนะนำ</h2>
    <div class="result" id="resultBox">
      <div class="r-title"><span class="ico"></span><span class="r-head"></span></div>
      <div class="r-body"></div>
    </div>
  </section>

  <!-- 6. Patient info (revealed only when consult needed) -->
  <section class="card" id="patientCard">
    <h2>ข้อมูลผู้ป่วย (สำหรับใบ Consult)</h2>
    <div class="grid">
      <div class="field full">
        <label>ชื่อ – นามสกุล</label>
        <input type="text" id="ptName" placeholder="เช่น นายสมชาย ใจดี" autocomplete="off">
      </div>
      <div class="field">
        <label>อายุ (ปี)</label>
        <input type="number" id="ptAge" min="0" max="130" inputmode="numeric" placeholder="0" autocomplete="off">
      </div>
      <div class="field">
        <label>HN</label>
        <input type="text" id="ptHN" inputmode="numeric" placeholder="0000000" autocomplete="off">
      </div>
    </div>
    <div class="privacy-note">
      🔒 <b>ความเป็นส่วนตัว:</b> ข้อมูลใช้แสดงในใบ Consult เท่านั้น
      ระบบ<b>ไม่บันทึก ไม่ส่งออก</b> ข้อมูลหายไปเมื่อปิดหน้า
    </div>
    <div class="actions">
      <button class="btn btn-primary btn-block" id="printBtn">🖨️ พิมพ์ใบ Consult</button>
    </div>
  </section>

  <p style="text-align:center;font-size:12px;color:var(--gray-500);margin-top:20px">
    เครื่องมือช่วยตัดสินใจ ไม่ทดแทนการพิจารณาของทันตแพทย์ผู้ดูแล
  </p>
</div>

<!-- ============ A4 CONSULT DOCUMENT ============ -->
<div id="consultDoc">
  <div class="doc-toolbar">
    <button class="btn btn-ghost" id="backBtn">← กลับไปแก้ไข</button>
    <button class="btn btn-primary" id="doPrintBtn">🖨️ สั่งพิมพ์</button>
  </div>
  <div class="a4">
    <div class="doc-head">
      <h2>โรงพยาบาลปัตตานี</h2>
      <p>กลุ่มภารกิจด้านทันตกรรม</p>
    </div>
    <div class="doc-title">ใบส่งปรึกษา (CONSULTATION RECORD)</div>

    <div class="pt-row">
      <span><b>ชื่อ–สกุล:</b> <span id="dName"></span></span>
      <span><b>อายุ:</b> <span id="dAge"></span> ปี</span>
      <span><b>HN:</b> <span id="dHN"></span></span>
    </div>
    <div class="pt-row">
      <span><b>วันที่:</b> <span id="dDate"></span></span>
      <span><b>ประเภท:</b> <span id="dProc"></span></span>
    </div>
    <div class="pt-row">
      <span><b>หัตถการ:</b> <span id="dProcedure"></span></span>
    </div>

    <div class="sec">
      <div class="sec-h">เรื่องที่ขอปรึกษา</div>
      <div class="body-txt" id="dConsultBody"></div>
    </div>

    <div class="sign">
      <div class="line">
        ลงชื่อ ............................................ ทันตแพทย์ผู้ส่งปรึกษา<br>
        (............................................)
      </div>
    </div>

    <div class="meta">
      เอกสารสร้างจากระบบช่วยตัดสินใจส่งปรึกษา กลุ่มงานทันตกรรม รพ.ปัตตานี — โปรดตรวจสอบความถูกต้องก่อนใช้งาน
    </div>
  </div>
</div>

<script>
/* =====================================================================
   ป้ายกำกับตัวเลือก (ใช้ในผลลัพธ์ + ใบ Consult)
   ===================================================================== */
const PROC_LABELS = {
  emergency: "Emergency (ฉุกเฉิน)",
  urgency:   "Urgency (เร่งด่วน)",
  elective:  "Elective (นัดล่วงหน้า)"
};
/* ตัวเลือกหัตถการเริ่มต้น (ใช้กับทุก Problem ที่ไม่กำหนด procedures เอง) */
const DEFAULT_PROCEDURES = [
  { value: "minor", dot: "🪥", label: "หัตถการเจ็บน้อย เลือดออกน้อย ผู้ป่วยกลัวต่ำ", sub: "เช่น อุดฟัน, ขูดหินปูน" },
  { value: "ext2",  dot: "🦷", label: "ถอนฟันไม่เกิน 2 ซี่" },
  { value: "surg",  dot: "🔪", label: "ถอนฟันมากกว่า 2 ซี่ / ผ่าตัดเล็กในช่องปาก" }
];

/* รายการหัตถการของ Problem ปัจจุบัน (ถ้า Problem กำหนด procedures เองให้ใช้อันนั้น) */
function currentProcedures() {
  const p = PROBLEMS[state.problem];
  return (p && p.procedures) ? p.procedures : DEFAULT_PROCEDURES;
}
function getProcedureLabel(value) {
  const f = currentProcedures().find(p => p.value === value);
  return f ? f.label : "-";
}

/* =====================================================================
   โครงสร้าง Problem List แบบขยายได้
   - questions: คำถามย่อยเฉพาะ Problem
   - evaluate(a, ctx): a = คำตอบย่อย, ctx = { proc, procedure }
       → { status:'green'|'red'|'amber'|null, title, message, consultBody }
   - buildConsult(a, ctx): ข้อความในใบ Consult
   ===================================================================== */
const PROBLEMS = {

  /* ---------- ความดันโลหิตสูง ---------- */
  ht: {
    label: "ความดันโลหิตสูง",

    /* หัตถการเฉพาะกรณีความดันสูง (แทนชุดเริ่มต้น) */
    procedures: [
      { value: "simple",  dot: "🪥", label: "หัตถการไม่ซับซ้อน เจ็บน้อย ผู้ป่วยกลัวต่ำ" },
      { value: "painful", dot: "⚡", label: "หัตถการที่มีความเจ็บปวด ผู้ป่วยกลัวมาก" }
    ],

    HT_PROC_LABEL: {
      simple:  "หัตถการไม่ซับซ้อน เจ็บน้อย ผู้ป่วยมีความกลัวต่ำ",
      painful: "หัตถการที่มีความเจ็บปวด ผู้ป่วยมีความกลัวมาก"
    },

    questions: [
      {
        /* เลือกกลุ่มความดัน — chip แนวนอน (เฉพาะ Urgency) */
        id: "group",
        label: "ระดับความดันโลหิต",
        type: "chipChoice",
        chipStack: false,
        clears: ["htProcedure", "atod"],
        options: [
          { value: "1", text: "ต่ำกว่า 140/90 mmHg",
            sub: ["SBP ต่ำกว่า 140 mmHg และ", "DBP ต่ำกว่า 90 mmHg"] },
          { value: "2", text: "140–159 / 90–99 mmHg",
            sub: ["SBP 140–159 mmHg หรือ", "DBP 90–99 mmHg"] },
          { value: "3", text: "160–179 / 100–109 mmHg",
            sub: ["SBP 160–179 mmHg หรือ", "DBP 100–109 mmHg"] },
          { value: "4", text: "180/110 mmHg ขึ้นไป",
            sub: ["SBP ≥ 180 mmHg หรือ", "DBP ≥ 110 mmHg"] }
        ],
        showIf: (a, ctx) => ctx.proc === "urgency" || ctx.proc === "elective"
      },
      {
        /* เลือกหัตถการเฉพาะ HT กลุ่ม 3 — chip แนวตั้ง */
        id: "htProcedure",
        label: "เลือกประเภทหัตถการที่จะทำ",
        type: "chipChoice",
        chipStack: true,
        options: [
          { value: "simple",  text: "หัตถการไม่ซับซ้อน เจ็บน้อย ผู้ป่วยมีความกลัวต่ำ",
                              sub:  "เช่น อุดฟัน, ขูดหินปูน" },
          { value: "painful", text: "หัตถการที่มีความเจ็บปวด ผู้ป่วยมีความกลัวมาก",
                              sub:  "เช่น ถอนฟัน, ผ่าตัดในช่องปาก" }
        ],
        showIf: (a, ctx) => ctx.proc === "urgency" && a.group === "3"
      },
      {
        /* Acute target organ damage — chip คู่ (กลุ่ม 4) */
        id: "atod",
        label: "มีอาการ Acute target organ damage หรือไม่?\n(เช่น ปวดศีรษะรุนแรง แน่นหน้าอก เจ็บหน้าอก ตามัว แขนขาอ่อนแรง)",
        type: "chipChoice",
        chipStack: false,
        options: [
          { value: "yes", text: "⛔ มีอาการ", sub: "Hypertensive emergency" },
          { value: "no",  text: "✅ ไม่มีอาการ" }
        ],
        showIf: (a, ctx) => (ctx.proc === "urgency" || ctx.proc === "elective") && a.group === "4"
      }
    ],

    evaluate(a, ctx) {
      /* ---- Emergency: รักษาทันทีภายใต้การ monitor ---- */
      if (ctx.proc === "emergency") {
        return {
          status: "green",
          title: "ให้การรักษาทันที",
          message: "คำแนะนำ\n"
