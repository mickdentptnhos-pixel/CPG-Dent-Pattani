          message: "สามารถให้การรักษาทางทันตกรรมได้ตามปกติ "
                 + "และแนะนำให้ผู้ป่วยไปพบแพทย์เพื่อรักษา/ควบคุมความดันโลหิตสูง"
        };

        if (g === "3") {
          if (!a.htProcedure) return { status: null };
          if (a.htProcedure === "simple") return {
            status: "amber",
            title: "พิจารณาให้การรักษาร่วมกับการ Monitor อย่างใกล้ชิด",
            message: "คำแนะนำ\n"
                   + "• วัดความดันโลหิตทุก 15 นาทีระหว่างทำหัตถการ\n"
                   + "• พิจารณาใช้ยาชาที่มี adrenaline (1:100,000) ไม่เกิน 2 cartridges หรือเลือกใช้ยาชาที่ไม่มี adrenaline\n"
                   + "• ลดความกลัวของผู้ป่วยอย่างเหมาะสม\n"
                   + "• ดำเนินหัตถการด้วย Painless technique\n"
                   + "• สังเกตอาการตลอดหัตถการ เช่น ปวดหัวรุนแรง แน่นหน้าอก ตามัว แขนขาอ่อนแรง"
          };
          return {
            status: "red", title: "ส่งปรึกษาอายุรกรรม",
            message: "หัตถการที่มีความเจ็บปวด ผู้ป่วยมีความกลัวมาก → "
                   + "ต้องส่งปรึกษาอายุรกรรมเพื่อประเมินและควบคุมความดันก่อนทำหัตถการ และนัดมารับการรักษาภายใน 2 วันทำการ",
            consultBody: true
          };
        }

        if (g === "4") {
          if (!a.atod) return { status: null };
          if (a.atod === "yes") return {
            status: "red", title: "ส่งห้องฉุกเฉินทันที (Hypertensive emergency)",
            message: "มีอาการ Acute target organ damage → "
                   + "งดทำหัตถการ และนำส่งห้องฉุกเฉินทันทีเพื่อรับการรักษาเร่งด่วน"
