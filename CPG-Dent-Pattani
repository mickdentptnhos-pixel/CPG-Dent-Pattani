        };

        if (g === "4") {
          if (!a.atod) return { status: null };
          if (a.atod === "yes") return {
            status: "red", title: "ส่งห้องฉุกเฉินทันที (Hypertensive emergency)",
            message: "มีอาการ Acute target organ damage — "
                   + "งดทำหัตถการทันที และนำส่งห้องฉุกเฉินเพื่อรับการรักษาเร่งด่วน"
          };
          return {
            status: "red", title: "ส่งปรึกษาอายุรกรรม",
            message: "ไม่มีอาการ Acute target organ damage — "
                   + "งดทำหัตถการ ส่งปรึกษาอายุรกรรมเพื่อประเมินและควบคุมความดันก่อนนัดทำหัตถการ",
            consultBody: true
          };
        }
      }

      return { status: null };
    },

    buildConsult(a, ctx) {
      const procTxt = a.htProcedure ? this.HT_PROC_LABEL[a.htProcedure] : "";
      return "ผู้ป่วยมีภาวะความดันโลหิตสูง"
           + (procTxt ? " ต้องการทำ" + procTxt : "")
           + " (ประเภทหัตถการ: " + PROC_LABELS[ctx.proc] + ") "
           + "ทางกลุ่มงานทันตกรรมขอความอนุเคราะห์อายุรแพทย์ประเมินและควบคุมความดันโลหิตก่อนทำหัตถการ";
    }
  },

  /* ---------- Warfarin (logic ใช้งานได้) ---------- */
  warfarin: {
    label: "Warfarin",
    questions: [
      {
        id: "inr", label: "มีผล INR ภายใน 72 ชั่วโมงหรือไม่?", type: "choice",
        clears: ["inrValue"],
        options: [
          { value: "yes", text: "✅ มีผล INR" },
          { value: "no",  text: "❌ ไม่มีผล INR" }
        ]
      },
      {
        id: "inrValue", label: "ค่าผล INR ล่าสุด", type: "number",
        placeholder: "เช่น 2.5", showIf: (a) => a.inr === "yes"
      }
    ],
    evaluate(a) {
      if (!a.inr) return { status: null };
      if (a.inr === "no") {
        return {
          status: "red", title: "ต้องส่ง Consult",
          message: "ไม่มีผล INR ภายใน 72 ชั่วโมง จึงไม่สามารถประเมินความเสี่ยงเลือดออกได้ ต้องส่งปรึกษาเพื่อประเมินและตรวจ INR ก่อนทำหัตถการ",
          consultBody: true
        };
      }
      const v = a.inrValue;
      if (v === undefined || v === null || v === "") return { status: null };
      const inr = parseFloat(v);
      if (isNaN(inr)) return { status: null };
      if (inr <= 3.0) {
        return {
          status: "green", title: "สามารถทำหัตถการได้",
          message: "ผล INR = " + inr.toFixed(1) + " (≤ 3.0) สามารถทำหัตถการได้ตามปกติ "
                 + "ห้ามเลือดด้วย Local hemostatic agent และสังเกตอาการเลือดออกหลังทำหัตถการ"
        };
      }
      return {
        status: "red", title: "ต้องส่ง Consult",
        message: "ผล INR = " + inr.toFixed(1) + " (> 3.0) มีความเสี่ยงเลือดออกสูง ต้องส่งปรึกษาเพื่อประเมินและปรับยาก่อนทำหัตถการ",
        consultBody: true
      };
    },
    buildConsult(a, ctx) {
      const inrTxt = (a.inr === "yes" && a.inrValue)
        ? "ผล INR ล่าสุด = " + parseFloat(a.inrValue).toFixed(1)
        : "ยังไม่มีผล INR ภายใน 72 ชั่วโมง";
      return "ผู้ป่วยรับประทานยา Warfarin (" + inrTxt + ") "
           + "ต้องการทำหัตถการ " + ctx.procedureLabel + " ____________________________ "
           + "ทางกลุ่มงานทันตกรรมขอความอนุเคราะห์ประเมินและพิจารณาปรับยา "
           + "เพื่อให้ผู้ป่วยสามารถเข้ารับการทำหัตถการทางทันตกรรมได้อย่างปลอดภัย";
    }
  },

  /* ---------- Aspirin (รอกำหนด logic) ---------- */
  aspirin: {
    label: "Aspirin",
    questions: [
      {
        id: "dose", label: "ขนาดยา Aspirin", type: "choice",
        options: [
          { value: "low",  text: "≤ 100 มก./วัน" },
          { value: "high", text: "> 100 มก./วัน" }
        ]
      }
    ],
    evaluate(a, ctx) {
      if (!a.dose) return { status: null };
      // TODO: ใส่เกณฑ์จริงเมื่อได้ logic
      return {
        status: "amber",
        title: "รอกำหนดเงื่อนไข (Aspirin)",
        message: "ขนาดยา: " + (a.dose === "low" ? "≤ 100 มก./วัน" : "> 100 มก./วัน")
               + " | ประเภท: " + PROC_LABELS[ctx.proc] + " | หัตถการ: " + ctx.procedureLabel
               + "\n\nยังไม่ได้กำหนดเกณฑ์ตัดสิน โปรดส่ง logic เพื่อให้ระบบประเมินอัตโนมัติ"
      };
    },
    buildConsult(a, ctx) {
      return "ผู้ป่วยรับประทานยา Aspirin (" + (a.dose === "low" ? "≤ 100" : "> 100") + " มก./วัน) "
           + "ต้องการทำหัตถการ " + ctx.procedureLabel
           + " ขอความอนุเคราะห์ประเมินและพิจารณาก่อนทำหัตถการ";
    }
  }
};

/* ===================== State & DOM ===================== */
const state = { proc: "", procedure: "", problem: "", answers: {} };
let pendingFocus = null; // id ของช่องตัวเลขที่กำลังพิมพ์ ใช้คืน focus หลัง re-render
const el = (id) => document.getElementById(id);
const decisionCard = el("decisionCard");
const decisionArea = el("decisionArea");
const resultCard = el("resultCard");
const resultBox = el("resultBox");
const patientCard = el("patientCard");

/* helper: toggle active ภายใน container เดียว */
function selectChip(container, chip) {
  container.querySelectorAll(".chip").forEach(c => c.classList.toggle("active", c === chip));
}

/* ===================== Step 1: Problem List ===================== */
el("problemChips").addEventListener("click", (e) => {
  const chip = e.target.closest(".chip");
  if (!chip) return;
  if (state.problem !== chip.dataset.problem) {
    state.proc = "";
    state.procedure = "";
    el("procChips").querySelectorAll(".chip").forEach(c => c.classList.remove("active"));
  }
  state.problem = chip.dataset.problem;
  state.answers = {};
  selectChip(el("problemChips"), chip);
  updateFlow();
});

/* ===================== Step 2: ประเภทหัตถการ ===================== */
el("procChips").addEventListener("click", (e) => {
  const chip = e.target.closest(".chip");
  if (!chip) return;
  state.proc = chip.dataset.proc;
  state.procedure = "";
  selectChip(el("procChips"), chip);
  updateFlow();
});

/* ===================== Render procedureChips (ตาม Problem ปัจจุบัน) ===================== */
function renderProcedureChips() {
  const container = el("procedureChips");
  container.innerHTML = "";
  currentProcedures().forEach((proc) => {
    const b = document.createElement("button");
    b.type = "button";
    b.dataset.procedure = proc.value;
    b.className = "chip" + (state.procedure === proc.value ? " active" : "");
    if (proc.dot) {
      const dot = document.createElement("span");
      dot.className = "dot";
      dot.textContent = proc.dot;
      b.appendChild(dot);
    }
    const textWrap = document.createElement("span");
    textWrap.textContent = proc.label;
    if (proc.sub) {
      const s = document.createElement("span");
      s.className = "sub";
      s.textContent = proc.sub;
      textWrap.appendChild(s);
    }
    b.appendChild(textWrap);
    container.appendChild(b);
  });
}

/* ===================== Step 3: หัตถการ ===================== */
el("procedureChips").addEventListener("click", (e) => {
  const chip = e.target.closest(".chip");
  if (!chip) return;
  state.procedure = chip.dataset.procedure;
  selectChip(el("procedureChips"), chip);
  updateFlow();
});

/* ===================== ควบคุมการเผยทีละขั้น =====================
   Emergency → ข้ามขั้นเลือกหัตถการ ไปประเมินผลทันทีหลังเลือก Problem
   ============================================================== */
function updateFlow() {
  el("procCard").style.display = state.problem ? "block" : "none";
  const procedureCard = el("procedureCard");

  if (!state.problem || !state.proc) {
    procedureCard.style.display = "none";
    decisionCard.style.display = "none";
    resultCard.style.display = "none";
    return;
  }

  // Emergency หรือ HT → ข้ามขั้นเลือกหัตถการ (HT มีหัตถการฝังในคำถามของตัวเอง)
  if (state.proc === "emergency" || state.problem === "ht") {
    procedureCard.style.display = "none";
    renderDecision();
    return;
  }

  // Urgency / Elective + non-HT → ต้องเลือกหัตถการก่อน
  renderProcedureChips();
  procedureCard.style.display = "block";
  if (state.procedure) {
    renderDecision();
  } else {
    decisionCard.style.display = "none";
    resultCard.style.display = "none";
  }
}

/* ===================== Render decision questions ===================== */
function renderDecision() {
  decisionArea.innerHTML = "";
  const p = PROBLEMS[state.problem];
  if (!p) { evaluate(); return; }

  const ctx = { proc: state.proc, procedure: state.procedure, procedureLabel: getProcedureLabel(state.procedure) };

  let hasQuestions = false;
  p.questions.forEach((q) => {
    if (q.showIf && !q.showIf(state.answers, ctx)) return;
    hasQuestions = true;

    const block = document.createElement("div");
    block.className = "sub-block";

    const lbl = document.createElement("div");
    lbl.className = "q-label";
    lbl.textContent = q.label;
    block.appendChild(lbl);

    if (q.type === "chipChoice") {
      /* chip-style: ใช้ CSS .chip/.chips เหมือน Problem List */
      const wrap = document.createElement("div");
      wrap.className = "chips" + (q.chipStack ? " stack" : "");
      q.options.forEach((opt) => {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "chip" + (state.answers[q.id] === opt.value ? " active" : "");
        const textWrap = document.createElement("span");
        textWrap.textContent = opt.text;
        if (opt.sub) {
          if (Array.isArray(opt.sub)) {
            const ul = document.createElement("ul");
            ul.className = "sub-list";
            opt.sub.forEach(item => { const li = document.createElement("li"); li.textContent = item; ul.appendChild(li); });
            textWrap.appendChild(ul);
          } else {
            const s = document.createElement("span");
            s.className = "sub";
            s.textContent = opt.sub;
            textWrap.appendChild(s);
          }
        }
        b.appendChild(textWrap);
        b.onclick = () => {
          state.answers[q.id] = opt.value;
          if (q.clears) q.clears.forEach(k => delete state.answers[k]);
          renderDecision();
        };
        wrap.appendChild(b);
      });
      block.appendChild(wrap);
    } else if (q.type === "choice") {
      const wrap = document.createElement("div");
      wrap.className = "choices";
      q.options.forEach((opt) => {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "choice" + (state.answers[q.id] === opt.value ? " active" : "");
        b.textContent = opt.text;
        b.onclick = () => {
          state.answers[q.id] = opt.value;
          if (q.clears) q.clears.forEach(k => delete state.answers[k]);
          renderDecision();
        };
        wrap.appendChild(b);
      });
      block.appendChild(wrap);
    } else if (q.type === "number") {
      const wrap = document.createElement("div");
      wrap.className = "inline-input";
      const inp = document.createElement("input");
      inp.type = "number";
      inp.id = "q_" + q.id;
      inp.step = "any";
      inp.inputMode = q.inputMode || "decimal";
      inp.placeholder = q.placeholder || "";
      inp.value = state.answers[q.id] || "";
      // re-render เพื่อให้คำถามย่อยที่ขึ้นกับค่าตัวเลข (เช่น ATOD กลุ่ม 4) โผล่/หาย
      inp.oninput = () => { state.answers[q.id] = inp.value; pendingFocus = q.id; renderDecision(); };
      wrap.appendChild(inp);
      block.appendChild(wrap);
    }
    decisionArea.appendChild(block);
  });

  decisionCard.style.display = hasQuestions ? "block" : "none";
  evaluate();

  // คืน focus ให้ช่องตัวเลขที่กำลังพิมพ์อยู่ (เพราะ DOM ถูกสร้างใหม่)
  if (pendingFocus) {
    const f = document.getElementById("q_" + pendingFocus);
    if (f) { f.focus(); const v = f.value; f.value = ""; f.value = v; } // วาง caret ท้ายสุด
    pendingFocus = null;
  }
}

/* ===================== Evaluate & show result ===================== */
function evaluate() {
  const p = PROBLEMS[state.problem];
  resultBox.className = "result";
  resultCard.style.display = "none";
  patientCard.style.display = "none";

  if (!p) return;
  const ctx = { proc: state.proc, procedure: state.procedure, procedureLabel: getProcedureLabel(state.procedure) };
  const r = p.evaluate(state.answers, ctx);
  if (!r || !r.status) return;

  const icons = { green: "✅", red: "⛔", amber: "⚠️" };
  resultCard.style.display = "block";
  resultBox.className = "result show " + r.status;
  resultBox.querySelector(".ico").textContent = icons[r.status] || "";
  resultBox.querySelector(".r-head").textContent = r.title;
  resultBox.querySelector(".r-body").textContent = r.message;

  if (r.consultBody) {
    patientCard.style.display = "block";
  }
}

/* ===================== Build & show A4 consult ===================== */
el("printBtn").onclick = () => {
  el("dName").textContent = el("ptName").value.trim() || "________________________";
  el("dAge").textContent  = el("ptAge").value.trim()  || "____";
  el("dHN").textContent   = el("ptHN").value.trim()   || "____________";
  el("dDate").textContent = formatThaiDate(new Date());
  el("dProc").textContent = PROC_LABELS[state.proc] || "-";
  // HT มีหัตถการของตัวเอง (ฝังในคำถาม) — ไม่ใช้ global procedure
  const p = PROBLEMS[state.problem];
  const htProcLabel = (state.problem === "ht" && state.answers.htProcedure)
    ? p.HT_PROC_LABEL[state.answers.htProcedure]
    : null;
  el("dProcedure").textContent = htProcLabel || getProcedureLabel(state.procedure) || "-";

  const ctx = { proc: state.proc, procedure: state.procedure, procedureLabel: getProcedureLabel(state.procedure) };
  el("dConsultBody").textContent = p.buildConsult(state.answers, ctx);

  el("app").style.display = "none";
  el("consultDoc").style.display = "block";
  window.scrollTo(0, 0);
};

el("backBtn").onclick = () => {
  el("consultDoc").style.display = "none";
  el("app").style.display = "block";
};
el("doPrintBtn").onclick = () => window.print();

/* ===================== Helper: Thai date ===================== */
function formatThaiDate(d) {
  const months = ["มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน",
                  "กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"];
  return d.getDate() + " " + months[d.getMonth()] + " พ.ศ. " + (d.getFullYear() + 543);
}
